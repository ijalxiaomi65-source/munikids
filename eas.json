{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "preview": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease"
      }
    },
    "preview-arm64": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "GRADLE_ABI_FILTERS": "arm64-v8a"
        }
      }
    },
    "preview-armv7": {
      "android": {
        "buildType": "apk",
        "gradleCommand": ":app:assembleRelease",
        "env": {
          "GRADLE_ABI_FILTERS": "armeabi-v7a"
        }
      }
    },
    "production": {
      "android": {
        "buildType": "app-bundle"
      }
    }
  }
}
